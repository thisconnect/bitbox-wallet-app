{
  "private": true,
  "name": "bitboxapp",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "preact build --no-sw --no-inline-css",
    "serve": "sirv build --port 8080 --cors --single",
    "dev": "preact watch",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "fix": "eslint --fix 'src/**/*.{js,jsx,ts,tsx}'",
    "fix-dry": "eslint --fix-dry-run 'src/**/*.{js,jsx,ts,tsx}'",
    "analyze": "preact build --analyze",
    "test": "jest ./test"
  },
  "babel": {
    "presets": [
      "es2017",
      "preact"
    ],
    "plugins": [
      "@babel/plugin-transform-react-jsx"
    ]
  },
  "browserslist": [
    "last 2 Chrome versions"
  ],
  "eslintIgnore": [
    "build/*"
  ],
  "dependencies": {
    "@zxing/library": "0.17.1",
    "i18next": "19.6.3",
    "i18next-locize-backend": "4.1.2",
    "linkstate": "1.1.1",
    "locize-editor": "2.2.2",
    "preact": "10.3.1",
    "preact-jsx-chai": "3.0.0",
    "preact-markup": "2.0.0",
    "preact-render-to-string": "5.1.4",
    "preact-router": "3.2.1",
    "react-i18next": "7.13.0",
    "sortablejs": "1.10.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx-source": "7.10.5",
    "@teamsupercell/typings-for-css-modules-loader": "2.2.1",
    "@types/enzyme": "3.10.5",
    "@types/jest": "26.0.9",
    "@types/webpack-env": "1.15.2",
    "@typescript-eslint/eslint-plugin": "3.9.0",
    "@typescript-eslint/parser": "3.9.0",
    "css-loader": "3.5.3",
    "enzyme": "3.11.0",
    "enzyme-adapter-preact-pure": "2.2.0",
    "eslint": "7.6.0",
    "eslint-plugin-react": "7.20.6",
    "eslint-plugin-react-hooks": "4.0.8",
    "jest": "26.2.2",
    "jest-preset-preact": "4.0.2",
    "preact-cli": "3.0.1",
    "preact-cli-plugin-env-vars": "1.2.1",
    "sirv-cli": "1.0.0-next.3",
    "typescript": "3.9.7"
  }
}
